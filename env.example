# Server
PORT=3000
NODE_ENV=development

# Postgres (used by server and migrations)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=zipzop
POSTGRES_USER=zipzop
POSTGRES_PASSWORD=zipzoppass

# Redis for BullMQ
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=replace_with_a_real_secret
JWT_EXPIRES_IN=7d

# OpenAI (optional)
OPENAI_API_KEY=

# Storage (local root paths)
TMP_DIR=/data/tmp
PROCESSED_DIR=/data/processed
